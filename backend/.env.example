# Backend Environment Variables
# Copiar este archivo a .env y completar con valores reales

# CORS - Orígenes permitidos (separados por comas)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Debug mode
DEBUG=True

# Configuración de rutas (opcional - si no está definido usa valores por defecto)
# BASE_DIR=./backend
# TEMPLATES_DIR=./backend/templates
# GENERATED_DIR=./backend/generated
